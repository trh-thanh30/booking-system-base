<div
  style='margin:0;padding:0;background:#fafafa;font-family:Arial,Helvetica,sans-serif;color:#18181b;'
>
  <table
    width='100%'
    cellpadding='0'
    cellspacing='0'
    style='background:#fafafa;padding:24px 0;'
  >
    <tr>
      <td align='center'>
        <table
          width='600'
          cellpadding='0'
          cellspacing='0'
          style='background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #f1f5f9;'
        >

          <!-- HEADER -->
          <tr>
            <td style='background:#fd81c0;padding:32px 24px;text-align:center;'>
              <h1
                style='margin:0;font-size:22px;color:#ffffff;letter-spacing:0.5px;'
              >
                Verify Your Account
              </h1>
              <p style='margin:8px 0 0;color:#ffe4f3;font-size:14px;'>
                One-time verification code
              </p>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td
              style='padding:36px 28px;text-align:center;font-size:15px;line-height:1.6;color:#4b5563;'
            >
              <p style='margin:0 0 18px;'>Hello, {{to}}</p>

              <p style='margin:0 0 18px;'>
                Thank you for choosing us. To complete your account
                verification, please use the code below:
              </p>

              <!-- CODE BOX -->
              <table
                align='center'
                cellpadding='0'
                cellspacing='0'
                style='margin:28px auto;background:#fff1f8;border-radius:10px;border:1px dashed #fd81c0;'
              >
                <tr>
                  <td style='padding:22px 40px;text-align:center;'>
                    <span
                      style='font-family:Courier,monospace;font-size:40px;font-weight:700;letter-spacing:10px;color:#fd81c0;'
                    >
                      {{code}}
                    </span>
                  </td>
                </tr>
              </table>

              <p
                style='margin:18px 0 0;font-size:14px;color:#ef4444;font-weight:600;'
              >
                This code will expire in
                {{ttl}}
                minutes.
              </p>

              <p style='margin:36px 0 0;font-size:14px;color:#6b7280;'>
                If you didn’t request this code, you can safely ignore this
                email.
              </p>
            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td
              align='center'
              class='footer-cell'
              style='background:#f7f7f7;border-top:1px solid #dddddd;padding:34px 24px 38px;font-size:13px;line-height:1.8;color:#8a8a8a;'
            >
              <div
                style='margin-bottom:18px;font-size:20px;line-height:1.2;font-weight:700;color:#fb2f9a;letter-spacing:2px;'
              >
                Moonshie Gel &#38; Polish
              </div>
              <div style='margin-bottom:18px;'>
                Regent Street, Liverpool, United Kingdom, L3 7BN<br />
                Email:
                <a
                  href='mailto:vinamsupply@gmail.com'
                  style='color:#8a8a8a;text-decoration:none;'
                >
                  vinamsupply@gmail.com
                </a>
              </div>
              <div style='margin-bottom:18px;'>
                &copy;
                {{year}}
                Moonshie Gel &#38; Polish. All rights reserved.
              </div>
              <div>
                This email was sent automatically. Please do not reply.
              </div>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</div>
