<mjml>
  <mj-head>
    <mj-title>{{subject}}</mj-title>
    <mj-preview>Your Moonshie verification code is {{code}}</mj-preview>
    <mj-attributes>
      <mj-all font-family="Arial, Helvetica, sans-serif" />
      <mj-text color="#3f3f46" font-size="15px" line-height="1.6" />
      <mj-section padding="0" />
      <mj-button background-color="#fb2f9a" border-radius="0" color="#ffffff" font-weight="700" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#f7f7f7" width="600px">
    <mj-section background-color="#ffffff" padding="24px 24px 10px">
      <mj-column>
        <mj-text align="center" color="#fb2f9a" font-size="22px" font-weight="800" padding="0">Moonshie Gel &amp; Polish</mj-text>
        <mj-text align="center" color="#8a8a8a" font-size="13px" padding="8px 0 0">One-time verification code</mj-text>
      </mj-column>
    </mj-section>
    <mj-section background-color="#fb2f9a" padding="8px 0">
      <mj-column><mj-spacer height="1px" /></mj-column>
    </mj-section>
    <mj-section background-color="#fff0f8" padding="34px 28px 24px">
      <mj-column>
        <mj-text align="center" color="#111111" font-size="26px" font-weight="700" padding="0 0 14px">Verify Your Account</mj-text>
        <mj-text align="center" padding="0">Use this code to complete your account verification.</mj-text>
      </mj-column>
    </mj-section>
    <mj-section background-color="#ffffff" padding="30px 28px">
      <mj-column>
        <mj-text align="center" padding="0 0 18px">Hello, {{to}}</mj-text>
        <mj-text align="center" padding="0 0 22px">Thank you for choosing us. Enter the code below to continue.</mj-text>
        <mj-table align="center" padding="0">
          <tr>
            <td align="center" style="background:#fff0f8;border:1px dashed #fb2f9a;padding:22px 24px;">
              <span style="font-family:Courier, monospace;font-size:40px;font-weight:700;letter-spacing:10px;color:#fb2f9a;">{{code}}</span>
            </td>
          </tr>
        </mj-table>
        <mj-text align="center" color="#dc2626" font-size="14px" font-weight="700" padding="22px 0 0">This code will expire in {{ttl}} minutes.</mj-text>
        <mj-text align="center" color="#71717a" font-size="13px" padding="26px 0 0">If you didn't request this code, you can safely ignore this email.</mj-text>
      </mj-column>
    </mj-section>
    <mj-section background-color="#f7f7f7" border-top="1px solid #dddddd" padding="30px 24px">
      <mj-column>
        <mj-text align="center" color="#fb2f9a" font-size="20px" font-weight="700" letter-spacing="2px" padding="0 0 14px">Moonshie Gel &amp; Polish</mj-text>
        <mj-text align="center" color="#8a8a8a" font-size="13px" padding="0">Sent by Vilatek Ltd- Vinam Liverpool Nail Supply<br />Email: <a href="mailto:admin@vinamnailsupply.co.uk" style="color:#8a8a8a;text-decoration:none;">admin@vinamnailsupply.co.uk</a><br />Add: EWM House, Regent Street, Liverpool, England</mj-text>
        <mj-text align="center" color="#8a8a8a" font-size="13px" padding="16px 0 0">&copy; {{year}} Moonshie Gel &amp; Polish. All rights reserved.</mj-text>
        <mj-text align="center" color="#8a8a8a" font-size="13px" padding="8px 0 0">This email was sent automatically. Please do not reply.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
