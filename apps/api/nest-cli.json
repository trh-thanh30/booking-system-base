{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": ["**/*.hbs"]
  },
  "projects": {
    "api": {
      "type": "application",
      "root": ".",
      "entryFile": "main",
      "sourceRoot": "src"
    },
    "worker:email": {
      "type": "application",
      "root": ".",
      "entryFile": "workers/email/worker.main",
      "sourceRoot": "src"
    }
  }
}
