{
  "name": "@repo/api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "files": [
    "dist",
    "prisma",
    "prisma.config.ts",
    "public",
    "scripts"
  ],
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "pnpm run start:dev",
    "debug": "pnpm run start:debug",
    "start": "nest start",
    "start:dev": "pnpm --filter @repo/shared run build && dotenv -e ../../.env.development -- nest start --watch",
    "start:debug": "pnpm --filter @repo/shared run build && dotenv -e ../../.env.development -- nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "start:worker": "cross-env NODE_ENV=production node dist/workers/email/worker.main.js",
    "start:worker:email": "pnpm --filter @repo/shared run build && dotenv -e ../../.env.development -- nest start worker:email --watch",
    "start:worker:email:prod": "cross-env NODE_ENV=production node dist/workers/email/worker.main.js",
    "start:worker:email:debug": "dotenv -e ../../.env.development -- nest start worker:email --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:strict": "eslint \"{src,apps,libs,test}/**/*.ts\" --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "pnpm --filter @repo/shared run build && cross-env NODE_ENV=test jest",
    "test:dev": "pnpm --filter @repo/shared run build && dotenv -e ../../.env.development -- cross-env NODE_ENV=development jest",
    "test:prod": "pnpm --filter @repo/shared run build && dotenv -e ../../.env.production -- cross-env NODE_ENV=production jest",
    "test:watch": "pnpm --filter @repo/shared run build && cross-env NODE_ENV=test jest --watch",
    "test:cov": "pnpm --filter @repo/shared run build && cross-env NODE_ENV=test jest --coverage",
    "test:debug": "cross-env NODE_ENV=test && node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test && jest --config ./test/jest-e2e.json",
    "prisma:migrate:reset:dev": "dotenv -e ../../.env.development -- npx prisma migrate reset",
    "prisma:migrate:reset:force": "dotenv -e ../../.env.development -- npx prisma migrate reset --force",
    "prisma:migrate": "dotenv -e ../../.env.development -- npx prisma migrate dev",
    "prisma:migrate:prod": "dotenv -e ../../.env.production -- npx prisma migrate deploy",
    "prisma:studio": "dotenv -e ../../.env.development -- npx prisma studio",
    "prisma:generate": "prisma generate",
    "db:push:dev": "dotenv -e ../../.env.development -- npx prisma db push",
    "db:push": "dotenv -e ../../.env.development -- npx prisma db push",
    "db:push:test": "dotenv -e ../../.env.test -- npx prisma db push",
    "db:push:prod": "dotenv -e ../../.env.production -- npx prisma db push",
    "db:seed:dev": "dotenv -e ../../.env.development -- ts-node prisma/seed.ts",
    "db:seed:test": "dotenv -e ../../.env.test -- ts-node prisma/seed.ts",
    "db:seed:prod": "dotenv -e ../../.env.production -- ts-node prisma/seed.production.ts",
    "test:users:dev": "cross-env NODE_ENV=development ts-node scripts/test_base_users_module.ts",
    "test:users:test": "cross-env NODE_ENV=test ts-node scripts/test_base_users_module.ts",
    "test:users:prod": "cross-env NODE_ENV=production ts-node scripts/test_base_users_module.ts",
    "tw:dev": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/tailwind.css --watch --verbose",
    "tw:build": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/tailwind.css --minify",
    "tw:build:dev": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/tailwind.css",
    "tw:clean": "rm -f ./public/css/tailwind.css",
    "tw:purge": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/tailwind.css --content 'src/**/*.{ts,js,html,hbs}' 'src/docs/templates/**/*.{hbs,ts}' --purge",
    "dev:full": "concurrently \"npm run start:dev\" \"npm run tw:dev\"",
    "build:full": "npm run tw:build && npm run build",
    "build:full:dev": "npm run tw:build:dev && npm run build",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@prisma/config": "^7.4.1",
    "@repo/shared": "workspace:*",
    "@sentry/nestjs": "^10.52.0",
    "@tailwindcss/cli": "^4.1.13",
    "argon2": "^0.44.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.61.0",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "cron": "^4.3.0",
    "dayjs": "^1.11.13",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.3",
    "google-auth-library": "^10.3.0",
    "handlebars": "^4.7.8",
    "hbs": "^4.2.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "marked": "^16.2.1",
    "mjml": "^5.2.1",
    "multer": "^2.1.1",
    "nanoid": "^5.1.5",
    "nodemailer": "^6.10.1",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "puppeteer-core": "^24.42.0",
    "reflect-metadata": "^0.2.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "rxjs": "^7.8.1",
    "signale": "^1.4.0",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.1.13",
    "unified": "^11.0.5",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/hbs": "^4.0.5",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.1",
    "@types/pg": "^8.16.0",
    "@types/stripe": "^8.0.417",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
